  audioClip: {fileID: 8300000, guid: 7b763bfb8ac02fc46a019629959781b1, type: 3}
  m_Text: "G\xF6revin amac\u0131 m\xFCmk\xFCn oldu\u011Funca k\u0131sa bir zamanda
    oklarla belirtilen yang\u0131nlara m\xFCdahale etmektir. Helikopterinin ta\u015F\u0131d\u0131\u011F\u0131
    su miktar\u0131 yang\u0131nlara m\xFCdahale ettik\xE7e azalacakt\u0131r."
