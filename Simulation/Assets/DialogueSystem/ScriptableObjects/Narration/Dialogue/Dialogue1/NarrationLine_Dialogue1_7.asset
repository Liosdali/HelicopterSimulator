  m_Speaker: {fileID: 11400000, guid: 9dd3082631238414f8db3e72be080f21, type: 2}
  audioClip: {fileID: 0}
  m_Text: "Ey T\xFCrk istikbalinin evlad\u0131! \u0130\u015Fte, bu ahval ve \u015Ferait
    i\xE7inde dahi vazifen, T\xFCrk istiklal ve cumhuriyetini kurtarmakt\u0131r.
    Muhta\xE7 oldu\u011Fun kudret, damarlar\u0131ndaki asil kanda mevcuttur."
