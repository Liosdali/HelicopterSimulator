  m_Speaker: {fileID: 11400000, guid: 9dd3082631238414f8db3e72be080f21, type: 2}
  audioClip: {fileID: 0}
  m_Text: " Mevcudiyetinin ve istikbalinin yeg\xE2ne temeli budur. Bu temel, senin
    en k\u0131ymetli hazinendir. \u0130stikbalde dahi seni bu hazineden mahrum etmek
    isteyecek d\xE2hil\xEE ve haric\xEE bedhahlar\u0131n olacakt\u0131r."
